# ─── Database ───
DATABASE_URL=postgresql+psycopg2://blacklion:blacklion@db:5432/black_lion_ai
REDIS_URL=redis://redis:6379/0

# ─── MetaTrader 5 (Wine bridge container "mt5", port 8001; native on Windows) ───
# The terminal is logged into the broker via VNC once (persists in the mt5 volume),
# so MT5_LOGIN/PASSWORD/SERVER stay blank here — the bridge attaches to the running,
# already-authenticated terminal. Fill them only for programmatic re-login.
MT5_BRIDGE_HOST=mt5
MT5_BRIDGE_PORT=8001
MT5_LOGIN=
MT5_PASSWORD=
MT5_SERVER=
# Feed / execution mode (decoupled — default is safest, signals only):
#   BL_MT5_DATA=1     analyse REAL MT5 candles (still PaperBroker → no orders)
#   BL_MT5_EXECUTE=1  place demo/live orders through MT5 (use a DEMO account!)
# Unset both → Yahoo feed + PaperBroker dry-run.
BL_MT5_DATA=
BL_MT5_EXECUTE=

# ─── Telegram (BLACK LION's OWN bot — separate from the old `analyze` bot) ───
# Create a NEW bot via @BotFather, a NEW group, add the bot as admin.
BL_TELEGRAM_BOT_TOKEN=
BL_TELEGRAM_CHAT_ID=        # the new group's id — ONLY this chat may issue commands (allowlist)

# ─── Binance / Bybit (phase 2+, optional) ───
BINANCE_API_KEY=
BINANCE_API_SECRET=
BYBIT_API_KEY=
BYBIT_API_SECRET=

# ─── Runtime ───
BL_ENV=development          # development | production
BL_CONFIG_DIR=configs
BL_BALANCE=10000            # dry-run account balance for position sizing
BL_SCAN_INTERVAL=1800       # seconds between watchlist scans (30 min)
BL_SCAN_TIMEFRAMES=M15:H1,H1:H4   # entry:context pairs scanned per symbol (more TFs = more signals)
BL_OUTCOME_INTERVAL=300     # seconds between SL/TP outcome checks (5 min)
BL_COOLDOWN_HOURS=3         # min hours between signals for the same symbol
BL_DIGEST_HOUR_UTC=16       # daily digest hour (16 UTC = 21:00 Tashkent)
DB_PATH=data/journal.db     # SQLite journal (mount a volume at /data in prod)
